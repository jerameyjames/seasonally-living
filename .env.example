# Canonical URL for metadata, sitemap, OG (no trailing slash)
# Production: https://seasonallyliving.com or your Vercel URL until cutover
# NEXT_PUBLIC_SITE_URL=https://seasonally-living.vercel.app

# Stitch (Google Stitch) — optional; document project id for MCP / handoffs
# STITCH_PROJECT_ID=

# Public booking + lead capture (safe to expose to the browser)
# NEXT_PUBLIC_SCHEDULER_URL=https://...
# NEXT_PUBLIC_LEAD_FORM_URL=https://...
