# Copy to `.env.local` for local dev (not committed).
# Canonical URL for metadata, sitemap, OG (no trailing slash).
# In Vercel: set for Production only (e.g. https://seasonally-living.vercel.app).
# Leave unset for Preview so each deployment uses VERCEL_URL — unless you add
# the same keys for Preview in the Vercel dashboard (recommended for PR previews).
# After custom domain: set to https://yourdomain.com
# NEXT_PUBLIC_SITE_URL=https://seasonally-living.vercel.app

# Stitch (Google Stitch) — optional; for MCP / handoffs (see docs/stitch.md)
# STITCH_PROJECT_ID=13771544954940531085
# STITCH_DESIGN_SYSTEM_ASSET_ID=6269b0f19bc94dc5960be1285e8f62af

# Public contact (shown in footer, /book, /contact) — also set in Vercel
NEXT_PUBLIC_CONTACT_PHONE=(509) 667-8833
NEXT_PUBLIC_CONTACT_EMAIL=sales@seasonallyliving.com
# Optional: explicit tel href if display is not parseable (E.164)
# NEXT_PUBLIC_CONTACT_PHONE_TEL=+15096678833

# Optional: when online booking is ready (Calendly, Lightspeed, etc.)
# NEXT_PUBLIC_SCHEDULER_URL=https://...
# NEXT_PUBLIC_LEAD_FORM_URL=https://...
