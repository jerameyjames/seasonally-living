# Canonical URL for metadata, sitemap, OG (no trailing slash)
# Production: https://seasonallyliving.com or your Vercel URL until cutover
# NEXT_PUBLIC_SITE_URL=https://seasonally-living.vercel.app

# Stitch (Google Stitch) — optional; for MCP / handoffs (see docs/stitch.md)
# STITCH_PROJECT_ID=13771544954940531085
# STITCH_DESIGN_SYSTEM_ASSET_ID=6269b0f19bc94dc5960be1285e8f62af

# Public contact (safe to expose to the browser) — footer, /book, /contact
# NEXT_PUBLIC_CONTACT_PHONE=(509) 555-0100
# Optional: explicit tel href if display is not parseable (E.164)
# NEXT_PUBLIC_CONTACT_PHONE_TEL=+15095550100
# NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com

# Optional: when online booking is ready (Calendly, Lightspeed, etc.)
# NEXT_PUBLIC_SCHEDULER_URL=https://...
# NEXT_PUBLIC_LEAD_FORM_URL=https://...
